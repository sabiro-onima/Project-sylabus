# ─── DATABASE ─────────────────────────────────────────────
POSTGRES_USER=sylabus_user
POSTGRES_PASSWORD=sylabus_pass
POSTGRES_DB=sylabus_db
DATABASE_URL=postgresql+asyncpg://sylabus_user:sylabus_pass@postgres:5432/sylabus_db

# ─── REDIS ────────────────────────────────────────────────
REDIS_PASSWORD=redis_pass
REDIS_URL=redis://:redis_pass@redis:6379/0

# ─── MINIO ────────────────────────────────────────────────
MINIO_ROOT_USER=minio_admin
MINIO_ROOT_PASSWORD=minio_password
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET_NAME=sylabus-exports

# ─── AUTH / JWT ───────────────────────────────────────────
SECRET_KEY=CHANGE_THIS_TO_A_LONG_RANDOM_STRING_IN_PRODUCTION
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── SSO (OAuth2 / SAML – do skonfigurowania z uczelnią) ──
SSO_ENABLED=false
SSO_CLIENT_ID=
SSO_CLIENT_SECRET=
SSO_AUTHORIZATION_URL=
SSO_TOKEN_URL=
SSO_USERINFO_URL=

# ─── MONITORING ───────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# ─── APP ──────────────────────────────────────────────────
APP_ENV=development
CORS_ORIGINS=["http://localhost:3000"]
